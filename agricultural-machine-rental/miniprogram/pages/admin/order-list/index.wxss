.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.status-tab {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
}

.status-tab.active {
  background: #07c160;
  color: #fff;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.order-status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.order-status.confirmed {
  background: #e3f2fd;
  color: #2196f3;
}

.order-status.completed {
  background: #e8f5e9;
  color: #4caf50;
}

.order-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.order-body {
  margin-bottom: 16rpx;
}

.order-row {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.order-label {
  width: 120rpx;
}

.order-price {
  color: #f44336;
  font-weight: 600;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-btn.confirm {
  background: #07c160;
  color: #fff;
}

.action-btn.complete {
  background: #2196f3;
  color: #fff;
}

.action-btn.cancel {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 搜索栏样式 */
.search-bar {
  margin: 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.search-input {
  height: 72rpx;
  padding: 0 32rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 删除按钮样式 */
.action-btn.delete {
  background: #f44336;
  color: #fff;
}
