.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.tips {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 32rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.machine-list {
  margin-bottom: 40rpx;
}

.machine-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.machine-image {
  width: 100%;
  height: 320rpx;
}

.machine-info {
  padding: 24rpx;
}

.machine-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.stock-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stock-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.stock-controls {
  display: flex;
  align-items: center;
}

.stock-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.stock-num {
  min-width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.machine-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.price-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #ff9800, #f57c00);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.delete-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #ff4757;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.init-btn {
  padding: 24rpx 48rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: none;
}

.init-btn::after {
  border: none;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.machine-tip {
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.price-list {
  margin-bottom: 32rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item:last-child {
  border-bottom: none;
}

.price-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.price-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-input {
  width: 140rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

/* 添加农机按钮 */
.add-machine-btn {
  margin-top: 24rpx;
  margin-bottom: 40rpx;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

/* 添加农机表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  resize: none;
}
