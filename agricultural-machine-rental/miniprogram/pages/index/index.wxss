.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.search-bar {
  padding: 24rpx;
  background: #fff;
}

.search-input {
  height: 72rpx;
  padding: 0 32rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.machine-list {
  padding: 24rpx;
}

.machine-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.machine-image {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
}

.machine-info {
  padding: 24rpx;
}

.machine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.machine-intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.machine-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-label {
  font-size: 26rpx;
  color: #07c160;
}

.stock-info {
  font-size: 24rpx;
  color: #666;
}

.stock-info.no-stock {
  color: #f44336;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
