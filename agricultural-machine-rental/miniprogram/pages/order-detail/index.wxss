.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.status-card {
  background: linear-gradient(135deg, #07c160, #04a649);
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.status-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.status-card .pending {
  color: #ff9800;
}

.status-card .confirmed {
  color: #2196f3;
}

.status-card .completed {
  color: #4caf50;
}

.status-card .cancelled {
  color: #999;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  max-width: 400rpx;
  text-align: right;
}

.info-value.phone {
  color: #07c160;
}

.info-row.total {
  margin-top: 8rpx;
}

.info-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #f44336;
}

.action-section {
  margin-top: 40rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  margin-bottom: 24rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.confirm {
  background: linear-gradient(135deg, #07c160, #04a649);
  color: #fff;
}

.action-btn.complete {
  background: linear-gradient(135deg, #2196f3, #1976d2);
  color: #fff;
}

.action-btn.cancel {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
