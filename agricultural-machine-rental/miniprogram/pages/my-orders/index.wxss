.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #fff;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #07c160, #04a649);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.user-openid {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.btn-small {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 24rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-small::after {
  border: none;
}

.admin-entry {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.entry-btns {
  display: flex;
  gap: 20rpx;
}

.entry-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #07c160, #04a649);
  border-radius: 16rpx;
  color: #fff;
}

.entry-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.entry-text {
  font-size: 28rpx;
}

.admin-manage {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #07c160;
}

.admin-list {
  border-top: 1rpx solid #f0f0f0;
}

.admin-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.admin-item:last-child {
  border-bottom: none;
}

.admin-info {
  flex: 1;
}

.admin-openid {
  display: block;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.admin-date {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.admin-remove {
  color: #f44336;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.orders-section {
  margin: 0 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.status-tab {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.status-tab.active {
  background: #07c160;
  color: #fff;
}

.order-list {
  border-top: 1rpx solid #f0f0f0;
}

.order-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-card:last-child {
  border-bottom: none;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.order-status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.order-status.confirmed {
  background: #e3f2fd;
  color: #2196f3;
}

.order-status.completed {
  background: #e8f5e9;
  color: #4caf50;
}

.order-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.order-body {
  margin-bottom: 12rpx;
}

.order-row {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.order-label {
  width: 160rpx;
}

.order-price {
  color: #f44336;
  font-weight: 600;
}

.order-footer {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 20rpx 0;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.modal-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.modal-btn::after {
  border: none;
}
