<view class="container">
  <!-- 用户信息栏 -->
  <view class="user-bar">
    <view class="user-info">
      <view class="user-avatar">👤</view>
      <view class="user-detail">
        <text class="user-name">{{isAdmin ? '管理员' : '用户'}}</text>
        <text class="user-openid">ID: {{openid}}</text>
      </view>
    </view>
    <view class="user-actions">
      <button class="btn-small" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="admin-entry" wx:if="{{isAdmin}}">
    <view class="entry-title">📊 管理功能</view>
    <view class="entry-btns">
      <view class="entry-btn" bindtap="goToMachineManage">
        <text class="entry-icon">🚜</text>
        <text class="entry-text">农机管理</text>
      </view>
      <view class="entry-btn" bindtap="goToAllOrders">
        <text class="entry-icon">📋</text>
        <text class="entry-text">全部订单</text>
      </view>
    </view>
  </view>

  <!-- 管理员管理 -->
  <view class="admin-manage" wx:if="{{isAdmin}}">
    <view class="section-header">
      <text class="section-title">👥 管理员管理</text>
      <view class="section-action" bindtap="toggleAdminModal">
        <text>添加管理员</text>
      </view>
    </view>
    
    <view class="admin-list">
      <view class="admin-item" wx:for="{{admins}}" wx:key="openid">
        <view class="admin-info">
          <text class="admin-openid">{{item.openid}}</text>
          <text class="admin-date">{{item.created_at}}</text>
        </view>
        <view class="admin-remove" wx:if="{{item.openid !== openid}}" bindtap="onRemoveAdmin" data-openid="{{item.openid}}">
          移除
        </view>
      </view>
    </view>
  </view>

  <!-- 用户订单列表 -->
  <view class="orders-section">
    <view class="section-header">
      <text class="section-title">📦 我的订单</text>
    </view>

    <!-- 状态筛选 -->
    <view class="status-tabs">
      <view class="status-tab {{statusFilter === '' ? 'active' : ''}}" bindtap="onFilterStatus" data-status="">全部</view>
      <view class="status-tab {{statusFilter === 'pending' ? 'active' : ''}}" bindtap="onFilterStatus" data-status="pending">待确认</view>
      <view class="status-tab {{statusFilter === 'confirmed' ? 'active' : ''}}" bindtap="onFilterStatus" data-status="confirmed">已确认</view>
      <view class="status-tab {{statusFilter === 'completed' ? 'active' : ''}}" bindtap="onFilterStatus" data-status="completed">已完成</view>
    </view>

    <!-- 订单列表 -->
    <view class="order-list">
      <view class="order-card" wx:for="{{orders}}" wx:key="_id" bindtap="onOrderTap" data-id="{{item._id}}">
        <view class="order-header">
          <text class="order-name">{{item.machine_name}}</text>
          <text class="order-status {{item.status}}">{{statusMap[item.status]}}</text>
        </view>
        <view class="order-body">
          <view class="order-row">
            <text class="order-label">业务类型：</text>
            <text class="order-value">{{item.usage_name}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">作业面积：</text>
            <text class="order-value">{{item.mu}} 亩</text>
          </view>
          <view class="order-row">
            <text class="order-label">联系电话：</text>
            <text class="order-value">{{item.customer_phone}}</text>
          </view>
          <view class="order-row">
            <text class="order-label">总费用：</text>
            <text class="order-price">¥{{item.total_price}}</text>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无订单</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 添加管理员弹窗 -->
  <view class="modal-mask" wx:if="{{showAdminModal}}" bindtap="toggleAdminModal">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">添加管理员</text>
        <view class="modal-close" bindtap="toggleAdminModal">✕</view>
      </view>
      <view class="modal-body">
        <input class="modal-input" placeholder="输入对方openid" bindinput="onAdminOpenidInput" value="{{newAdminOpenid}}" />
        <view class="modal-tip">让对方在"我的订单"页面查看自己的openid</view>
        <button class="modal-btn" bindtap="onAddAdmin">确认添加</button>
      </view>
    </view>
  </view>
</view>
