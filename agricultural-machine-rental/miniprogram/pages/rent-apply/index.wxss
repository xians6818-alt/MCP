.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.machine-card {
  background: #fff;
  margin-bottom: 24rpx;
}

.machine-image {
  width: 100%;
  height: 400rpx;
}

.machine-info {
  padding: 24rpx;
}

.machine-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.machine-intro {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.stock-notice {
  font-size: 26rpx;
  color: #07c160;
}

.stock-notice.no-stock {
  color: #f44336;
}

.form-section {
  background: #fff;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #f44336;
  margin-right: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.usage-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.usage-item {
  width: calc(33.33% - 12rpx);
  padding: 20rpx 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
}

.usage-item.active {
  background: #e8f5e9;
  border-color: #07c160;
}

.usage-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.usage-price {
  font-size: 24rpx;
  color: #07c160;
}

.usage-item.active .usage-price {
  color: #07c160;
}

.land-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.land-input {
  flex: 1;
}

.land-unit {
  font-size: 28rpx;
  color: #666;
}

.fee-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-label {
  font-size: 28rpx;
  color: #333;
}

.fee-value {
  display: flex;
  align-items: baseline;
}

.fee-symbol {
  font-size: 28rpx;
  color: #f44336;
}

.fee-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #f44336;
}

.fee-detail {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.submit-section {
  padding: 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #04a649);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  background: #ccc;
}

.submit-btn::after {
  border: none;
}
